# GrowMoney — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Phase 3: Real Market Data ───────────────────────────────────────────────
# Set VITE_USE_REAL_DATA=true to switch from mock data to Supabase Edge Function
VITE_USE_REAL_DATA=false

# ─── Phase 3: Supabase ───────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Set to true to enable user data sync + real rankings
VITE_USE_SUPABASE=false

# ─── Phase 3: Toss 앱인토스 ───────────────────────────────────────────────────
# Provided by Toss after app registration
# VITE_TOSS_MINI_APP_ID=YOUR_APP_ID
